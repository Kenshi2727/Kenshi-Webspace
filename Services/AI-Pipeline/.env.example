# ============================================
# Kenshi AI Pipeline — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Server ---
PORT=4000
NODE_ENV=development
# Service-to-service auth key (shared with Node.js Server)
SERVICE_API_KEY=your-internal-service-key

# --- Google Gemini (Primary LLM — Free Tier) ---
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (Fallback LLM — Free Tier) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- HuggingFace (Fallback LLM + Image — Free Tier) ---
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_TEXT_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# --- Ollama (Local Dev Fallback) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Pollinations.ai (Primary Image Gen — Free, No Key) ---
POLLINATIONS_BASE_URL=https://image.pollinations.ai

# --- Stability AI (Fallback Image Gen — Free Credits) ---
STABILITY_API_KEY=your-stability-api-key

# --- Sentry (Error Monitoring) ---
SENTRY_DSN=your-sentry-dsn

# --- Logging ---
LOG_LEVEL=info
